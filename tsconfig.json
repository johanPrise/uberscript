{
  "compilerOptions": {
    "target": "es2022",                
    "module": "ESNext",           
    "strict": true,                 
    "esModuleInterop": true,        
    "forceConsistentCasingInFileNames": true, 
    "skipLibCheck": true,           
    "outDir": "./dist",             
    "rootDir": "./src"              
  },
  "include": ["src"],               
  "exclude": ["node_modules", "dist"] 
}